# ANVIL secrets — copy to `.env` and fill in. Load with: set -a; . ./.env; set +a
# (or use direnv / systemd EnvironmentFile). Never commit the real .env.

# Anthropic API key — enables the Claude ladder rungs (haiku/sonnet/opus/fable).
# No key = those rungs are skipped gracefully and the ladder degrades to
# whatever else is configured.
ANTHROPIC_API_KEY=

# OpenAI API key — only used by the optional generate_image tool (gpt-image-1).
OPENAI_API_KEY=

# Ollama Cloud key — enables the ollama_cloud provider rungs, if you run any.
OLLAMA_API_KEY=

# Override the local Ollama host if not on the default port.
# OLLAMA_HOST=http://localhost:11434

# Gitea (self-dev): the harness's own token for issues/PRs/pushes, and an
# optional second token for a human operator account (issue comments that
# should NOT appear to come from the assistant).
GITEA_TOKEN=
OPERATOR_GITEA_TOKEN=

# Discord webhook for outbound notifications (optional; Web Push via the PWA
# needs no keys — VAPID keys are generated locally on first use).
DISCORD_WEBHOOK_URL=

# Discord bot token for two-way control from your phone (needs discord.py).
DISCORD_BOT_TOKEN=

# Optional: override the daily paid-escalation cap (USD).
# ANVIL_DAILY_CAP=5.0

# Home Assistant integration — senses + approval-gated actions.
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=                # long-lived access token from HA profile page
# HA_TIMEOUT_S=5           # HTTP request timeout in seconds (default 5)

# Remote nodes: the `ssh` tool needs NO env vars — it uses OpenSSH key auth from
# the operator's ~/.ssh (BatchMode, never prompts). Set up passwordless keys to
# the nodes you want ANVIL to reach; every ssh call still pauses for approval.
